HA_BRIDGE_URL=http://localhost:8092

AGENT_MEMORY_MAX_TURNS=12
AGENT_TOOL_AUTO_EXECUTE=true
AGENT_ACTION_TIMEOUT_SECONDS=6
AGENT_TOKEN_BUDGET=1600
AGENT_MULTI_STEP_ENABLED=true
AGENT_MAX_PLAN_STEPS=5
AGENT_ROLLBACK_ON_FAILURE=true
AGENT_USE_LLM_TOOL_ROUTER=true
AGENT_USE_LLM_INTENT_ROUTER=true
AGENT_INTENT_MIN_CONFIDENCE=0.60
AGENT_CANDIDATE_TOOL_LIMIT=20
AGENT_RUNTIME_ENV=home
AGENT_DEFAULT_ROLE=operator
AGENT_TRACE_MAX_ITEMS=200
AGENT_TOOL_WHITELIST=home.lights.on,home.lights.off,home.scene.activate,home.climate.set_temperature

AGENT_PROMPT_INJECTION_GUARD_ENABLED=true
AGENT_PROMPT_INJECTION_PATTERNS=ignore previous instructions,system prompt,developer prompt,越狱,请忽略之前,执行任意命令,泄露提示词

AGENT_LONG_TERM_MEMORY_ENABLED=true
AGENT_LONG_TERM_MEMORY_TOP_K=3
AGENT_LONG_TERM_MEMORY_LIMIT=300
AGENT_FAISS_INDEX_PATH=./data/memory/faiss.index
AGENT_FAISS_META_DB_PATH=./data/memory/memory.db
AGENT_FAISS_MIN_SCORE=0.10
AGENT_FAISS_AUTO_FLUSH_EVERY=1

HA_CONTEXT_ENABLED=true
HA_CONTEXT_PATH=/v1/context/summary
HA_CONTEXT_TTL_SECONDS=30
HA_CONTEXT_TIMEOUT_SECONDS=6
HA_CONTEXT_MAX_SERVICE_DOMAINS=12
HA_CONTEXT_MAX_CHARS=2400

# Unified LLM provider config
LLM_ENABLED=true
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-r1:1.5b
LLM_TIMEOUT_SECONDS=20
LLM_MAX_HISTORY_TURNS=6
LLM_SYSTEM_PROMPT=你是家庭语音助手。回答简洁直接，优先给出可执行建议，不要编造事实。

# Ollama provider config
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible provider config
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_CHAT_PATH=/v1/chat/completions
OPENAI_TEMPERATURE=0.3

# Embedding config (for vector generation only)
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_PATH=/v1/embeddings
EMBEDDING_TIMEOUT_SECONDS=12

# Backward-compatible aliases (optional)
OLLAMA_ENABLED=true
OLLAMA_MODEL=deepseek-r1:1.5b
OLLAMA_TIMEOUT_SECONDS=20
OLLAMA_MAX_HISTORY_TURNS=6
